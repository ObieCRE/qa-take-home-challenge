{
  "name": "qa-eng-take-home",
  "private": true,
  "workspaces": [
    "apps/server",
    "apps/web"
  ],
  "scripts": {
    "dev": "concurrently \"yarn dev:server\" \"yarn dev:web\"",
    "dev:server": "yarn workspace server dev",
    "dev:web": "yarn workspace web dev",
    "build": "yarn workspace web build",
    "test:e2e": "yarn playwright test",
    "test:e2e:ui": "yarn playwright test --ui",
    "test:solution": "yarn playwright test --config=playwright.solution.config.ts",
    "test:solution:ui": "yarn playwright test --config=playwright.solution.config.ts --ui",
    "package": "bash scripts/package-challenge.sh"
  },
  "devDependencies": {
    "@playwright/test": "^1.52.0",
    "@types/node": "^25.6.0",
    "concurrently": "^9.1.2"
  },
  "packageManager": "yarn@4.14.1"
}
